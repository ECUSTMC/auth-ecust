{% if providers|length > 0 %}
  <div class="my-3 text-center">
    <div class="mb-1">{{ trans('AuthEcust::auth.title') }}</div>
    {% for name, provider in providers %}
      <a href="{{ url("/auth/#{name}") }}" class="btn btn-block bg-light border-secondary">
        <i class="fa-{{ provider.icon }}"></i>&nbsp;
        {{ provider.displayName }}
      </a>
    {% endfor %}
  </div>
{% endif %}
