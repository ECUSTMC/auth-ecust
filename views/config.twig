{% extends 'admin.base' %}

{% block title %}{{ trans('AuthEcust::general.title') }}{% endblock %}

{% block content %}
  <div class="row">
    <div class="col-md-6">
      <div class="card card-info">
        <div class="card-header">
          <h3 class="card-title">{{ trans('AuthEcust::general.title') }}</h3>
        </div>
        <div class="card-body">
          <p>{{ trans('AuthEcust::general.description') }}</p>
          <hr>
          <h5>{{ trans('AuthEcust::config.channel_control') }}</h5>
          <form id="channel-form">
            <div class="form-group">
              <div class="custom-control custom-switch">
                <input type="checkbox" class="custom-control-input" id="switch-official" name="official_enabled" {{ official_enabled ? 'checked' : '' }}>
                <label class="custom-control-label" for="switch-official">{{ trans('AuthEcust::config.official') }}</label>
              </div>
              <small class="text-muted">{{ trans('AuthEcust::config.official_desc') }}</small>
            </div>
            <div class="form-group">
              <div class="custom-control custom-switch">
                <input type="checkbox" class="custom-control-input" id="switch-smtp" name="smtp_enabled" {{ smtp_enabled ? 'checked' : '' }}>
                <label class="custom-control-label" for="switch-smtp">{{ trans('AuthEcust::config.smtp') }}</label>
              </div>
              <small class="text-muted">{{ trans('AuthEcust::config.smtp_desc') }}</small>
            </div>
            <div class="form-group">
              <div class="custom-control custom-switch">
                <input type="checkbox" class="custom-control-input" id="switch-eduroam" name="eduroam_enabled" {{ eduroam_enabled ? 'checked' : '' }}>
                <label class="custom-control-label" for="switch-eduroam">{{ trans('AuthEcust::config.eduroam') }}</label>
              </div>
              <small class="text-muted">{{ trans('AuthEcust::config.eduroam_desc') }}</small>
            </div>
          </form>
          <hr>
          <h5>{{ trans('AuthEcust::config.email_rules') }}</h5>
          <p>5{{ trans('AuthEcust::config.digit_employee') }} <code>@ecust.edu.cn</code>{{ trans('AuthEcust::config.staff') }}</p>
          <p>{{ trans('AuthEcust::config.other_student') }} <code>@mail.ecust.edu.cn</code>{{ trans('AuthEcust::config.student') }}</p>
        </div>
      </div>
    </div>
  </div>
{% endblock %}

{% block before_foot %}
  <script>
    document.querySelectorAll('#channel-form input[type=checkbox]').forEach(function(el) {
      el.addEventListener('change', function() {
        var formData = new FormData();
        document.querySelectorAll('#channel-form input[type=checkbox]').forEach(function(cb) {
          if (cb.checked) {
            formData.append(cb.name, '1');
          }
        });
        blessing.fetch.post(window.location.href, formData).then(function(res) {
          if (res.code === 0) {
            blessing.notify.toast(res.message, 'success');
          }
        });
      });
    });
  </script>
{% endblock %}
